# Postgres connection string (Vercel Postgres / Neon / Supabase all work).
# Get this from your Vercel project's Storage tab after provisioning a
# Postgres database, or from your Neon project dashboard.
DATABASE_URL="postgres://user:password@host:5432/dbname?sslmode=require"

# Shared secret used to authorize the /api/ingest cron endpoint. Generate
# with `openssl rand -hex 32`. Vercel automatically sends this as
# `Authorization: Bearer <value>` to your Cron Job invocations once it's set
# as a project environment variable — see https://vercel.com/docs/cron-jobs/manage-cron-jobs#securing-cron-jobs
CRON_SECRET="replace-with-a-long-random-value"

# Optional but recommended in production: Upstash Redis REST credentials for
# rate limiting (proxy.ts and /api/ingest). Without these, rate limiting is
# disabled (fail-open) and a warning is logged. Free tier: https://upstash.com
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Optional: your deployed URL, used for absolute metadata/Open Graph/sitemap
# links. Set to e.g. "https://your-project.vercel.app" after first deploy.
NEXT_PUBLIC_SITE_URL=""
